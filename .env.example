# Application Configuration
APP_NAME=emotion-ml
APP_VERSION=1.0.0
DEBUG=False

# Data Paths
TRAIN_DATA_PATH=data/training_data.csv
TEST_DATA_PATH=data/test_data.csv

# Model Configuration
MODEL_SAVE_PATH=models/
RESULTS_SAVE_PATH=results/
LOG_FILE=results/pipeline.log

# Model Parameters
EMOTION_MODEL_TYPE=ensemble
INTENSITY_MODEL_TYPE=xgboost
CONFIDENCE_THRESHOLD=0.7

# Feature Engineering
MIN_TEXT_LENGTH=5
MAX_FEATURES=100
USE_TF_IDF=True
USE_SENTIMENT=True

# Logging
LOG_LEVEL=INFO
VERBOSE=True